# Example .env.local (DO NOT COMMIT SECRETS)
# Copy this to `.env.local` and fill values. Keep secret values out of version control.

# Public (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only secrets (DO NOT prefix with NEXT_PUBLIC_)
# Use these only in server-side code / API routes
SUPABASE_SERVICE_ROLE_KEY=service_role_xxx   # Required for inserts into `leads` and admin ops
RESEND_API_KEY=resend_sk_xxx                 # Optional: transactional emails
GEMINI_API_KEY=gemini_sk_xxx                 # Optional: LLM summary generation

# Optional: override the Gemini model used for summaries
GEMINI_MODEL=gemini-2.0-flash

# Optional: Upstash Redis rate limiting for public API routes
UPSTASH_REDIS_REST_URL=https://your-upstash-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=upstash_rest_token_xxx

# Optional: override host/origin used in emails (useful in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Notes:
# - `NEXT_PUBLIC_*` vars are bundled to the client. Keep only non-sensitive values there.
# - Keep `SUPABASE_SERVICE_ROLE_KEY`, `RESEND_API_KEY`, `GEMINI_API_KEY`, and Upstash tokens private and
#   only configured in your deployment provider's secret/env settings.
